let cart = JSON.parse(localStorage.getItem("cart")) || [];

function saveCart(){
    localStorage.setItem("cart", JSON.stringify(cart));
}

window.addToCart = function(name, price){
    cart.push({name, price});
    saveCart();
    updateCart();
}

window.toggle = function(id){
    document.querySelectorAll(".shop-section").forEach(sec=>{
        sec.classList.toggle("active", sec.id === id);
        if(sec.id !== id) sec.classList.remove("active");
    });
}

window.toggleCart = function(){
    document.getElementById("cartBox").classList.toggle("hidden");
}

window.removeItem = function(i){
    cart.splice(i,1);
    saveCart();
    updateCart();
}

function updateCart(){

    document.getElementById("count").innerText = cart.length;

    let box = document.getElementById("cartItemsSmall");
    box.innerHTML = "";

    let total = 0;

    cart.forEach((item,i)=>{
        total += item.price;

        box.innerHTML += `
            <div>
                ${item.name} - €${item.price.toFixed(2)}
                <button onclick="removeItem(${i})">X</button>
            </div>
        `;
    });

    box.innerHTML += `<p>Total: €${total.toFixed(2)}</p>`;
}

updateCart();
